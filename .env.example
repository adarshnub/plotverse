# Plotverse runtime
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
# If these are absent, Plotverse uses .local-data/plotverse.json.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
# If OPENAI_API_KEY is absent, matching and drafts use local fallback text.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
